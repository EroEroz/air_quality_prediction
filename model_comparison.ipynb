    "# 5. COMPARISON & EVALUATION\n",
    "# Calculate Error Metrics\n",
    "def get_metrics(y_true, y_pred, name):\n",
    "    mae = mean_absolute_error(y_true, y_pred)\n",
    "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "    r2 = r2_score(y_true, y_pred)\n",
    "    print(f\"[{name}] MAE: {mae:.2f} | RMSE: {rmse:.2f} | R2: {r2:.3f}\")\n",
    "    return mae, rmse, r2\n",
    "\n",
    "lr_mae, lr_rmse, lr_r2 = get_metrics(y_test, y_pred_lr, \"Linear Reg\")\n",
    "lstm_mae, lstm_rmse, lstm_r2 = get_metrics(y_test, y_pred_lstm, \"LSTM\")\n",
    "bilstm_mae, bilstm_rmse, bilstm_r2 = get_metrics(y_test, y_pred_bilstm, \"Bi-LSTM\")\n",
    "\n",
    "# Log comparison table\n",
    "comparison_data = {\n",
    "    \"Model\": [\"Linear Regression\", \"LSTM\", \"Bi-LSTM\"],\n",
    "    \"MAE\": [lr_mae, lstm_mae, bilstm_mae],\n",
    "    \"RMSE\": [lr_rmse, lstm_rmse, bilstm_rmse],\n",
    "    \"R2\": [lr_r2, lstm_r2, bilstm_r2]\n",
    "}\n",
    "comparison_df = pd.DataFrame(comparison_data)\n",
    "wandb.log({\"model_comparison_table\": wandb.Table(dataframe=comparison_df)})\n",
    "\n",
    "# Plot first 200 hours of Test Data\n",
    "fig, ax = plt.subplots(figsize=(15, 6))\n",
    "limit = 200\n",
    "\n",
    "ax.plot(y_test[:limit], label='Actual Data', color='black', linewidth=2, alpha=0.7)\n",
    "ax.plot(y_pred_lstm[:limit], label='LSTM', color='blue')\n",
    "ax.plot(y_pred_bilstm[:limit], label='Bi-LSTM', color='red', alpha=0.8)\n",
    "\n",
    "ax.set_title('Model Comparison: First 200 Hours of Prediction (2022)')\n",
    "ax.set_ylabel('PM2.5 Concentration')\n",
    "ax.set_xlabel('Time (Hours)')\n",
    "ax.legend()\n",
    "ax.grid(True)\n",
    "plt.tight_layout()\n",
    "\n",
    "# Log plot to wandb\n",
    "wandb.log({\"prediction_comparison_plot\": wandb.Image(fig)})\n",
    "plt.show()\n",
    "\n",
    "# Log summary metrics\n",
    "wandb.log({\n",
    "    \"best_model\": \"Bi-LSTM\" if bilstm_r2 == max(lr_r2, lstm_r2, bilstm_r2) else (\"LSTM\" if lstm_r2 == max(lr_r2, lstm_r2, bilstm_r2) else \"Linear Regression\"),\n",
    "    \"best_r2_score\": max(lr_r2, lstm_r2, bilstm_r2)\n",
    "})\n",
