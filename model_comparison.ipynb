    "print(f\"\\n[BiLSTM] F1-Weighted: {bilstm_f1_weighted:.4f} | F1-Macro: {bilstm_f1_macro:.4f} | Balanced Acc: {bilstm_balanced_acc:.4f} | ROC-AUC: {bilstm_roc_auc:.4f}\")"
